<PersonalCalendarGroup
    Title="StartSCH kategóriák"
    Items="StartSchCalendars"
    ShowBorder="@false"
    AddCallback="@(async () =>
                 {
                     await SaveCallback.InvokeAsync(_addDialogModel);
                     StartSchCalendars.Add(_addDialogModel);
                     _addDialogModel = new();
                 })"
    SaveCallback="@SaveCallback"
    DeleteCallback="@DeleteCallback"
>
    <ItemTemplate Context="item">
        <StartSchInput
            @key="@item"
            Model="@item"
            SaveCallback="@(() => SaveCallback.InvokeAsync(item))"
        />
    </ItemTemplate>
    <AddDialogHeadline>
        Új StartSCH kategória létrehozása
    </AddDialogHeadline>
    <AddDialogContent>
        <MdFilledTextField
            label="Név"
            style="display: flex"
            autofocus
            @bind-Value="@_addDialogModel.Name"
        />
    </AddDialogContent>
</PersonalCalendarGroup>

@code {
    private PersonalStartSchCalendarLive _addDialogModel = new();

    [Parameter, EditorRequired] public List<PersonalStartSchCalendarLive> StartSchCalendars { get; set; }
    [Parameter, EditorRequired] public EventCallback<PersonalCalendarLive> DeleteCallback { get; set; }
    [Parameter, EditorRequired] public EventCallback<PersonalCalendarLive> SaveCallback { get; set; }
}
