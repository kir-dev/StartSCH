@code {
    private readonly List<PersonalStartSchCalendarLive> _startSchs = [];
    private readonly List<PersonalNeptunCalendarLive> _neptuns = [];
    private readonly List<PersonalMoodleCalendarLive> _moodles = [];

    [Parameter, EditorRequired] public required List<PersonalCalendarLive>? InitialPersonalCalendars { get; set; }

    protected override void OnInitialized()
    {
        if (InitialPersonalCalendars == null)
            return;
        foreach (var personalCalendar in InitialPersonalCalendars)
        {
            switch (personalCalendar)
            {
                case PersonalStartSchCalendarLive startSchCalendar:
                    _startSchs.Add(startSchCalendar);
                    break;
                case PersonalNeptunCalendarLive neptunCalendar:
                    _neptuns.Add(neptunCalendar);
                    break;
                case PersonalMoodleCalendarLive moodleCalendar:
                    _moodles.Add(moodleCalendar);
                    break;
            }
        }
    }

    private async Task Delete(PersonalCalendarLive calendar)
    {
        using var response = await HttpClient.DeleteAsync($"/calendars/personal/{calendar.Id}");
        response.EnsureSuccessStatusCode();
    }
}
