<PersonalCalendarGroup Title="StartSCH kategóriák" Add="@(() => _startSchs.Add(new()))">
    <Calendars>
        @for (int i = 0; i < _startSchs.Count; i++)
        {
            var calendar = _startSchs[i];
            int index = i;
            <StartSchInput @key="@calendar" Model="@calendar" OnDelete="@(() => _startSchs.RemoveAt(index))"/>
        }
    </Calendars>
    <AddDialog></AddDialog>
</PersonalCalendarGroup>

<PersonalCalendarGroup Title="Neptun" Add="@(() => _neptuns.Add(new()))">
    <Calendars>
        @for (int i = 0; i < _neptuns.Count; i++)
        {
            var calendar = _neptuns[i];
            int index = i;
            <NeptunInput @key="@calendar" Model="@calendar" OnDelete="@(() => _neptuns.RemoveAt(index))"/>
        }
    </Calendars>
    <AddDialog></AddDialog>
    <Ports>
        Ports
    </Ports>
</PersonalCalendarGroup>

<PersonalCalendarGroup Title="Moodle" Add="@(() => _moodles.Add(new()))">
    <Calendars>
        @for (int i = 0; i < _moodles.Count; i++)
        {
            var calendar = _moodles[i];
            int index = i;
            <MoodleInput @key="@calendar" Model="@calendar" OnDelete="@(() => _moodles.RemoveAt(index))"/>
        }
    </Calendars>
    <AddDialog>
        AAAAAAAAAAA
    </AddDialog>
    <Ports>
        Ports
    </Ports>
</PersonalCalendarGroup>

@code {

    [Parameter, EditorRequired] public required List<PersonalCalendarLive>? InitialPersonalCalendars { get; set; }

    protected override void OnInitialized()
    {
        if (InitialPersonalCalendars == null)
            return;
        foreach (var personalCalendar in InitialPersonalCalendars)
        {
            switch (personalCalendar)
            {
                case PersonalStartSchCalendarLive startSchCalendar:
                    _startSchs.Add(startSchCalendar);
                    break;
                case PersonalNeptunCalendarLive neptunCalendar:
                    _neptuns.Add(neptunCalendar);
                    break;
                case PersonalMoodleCalendarLive moodleCalendar:
                    _moodles.Add(moodleCalendar);
                    break;
            }
        }
    }

    private readonly List<PersonalStartSchCalendarLive> _startSchs = [];
    private readonly List<PersonalNeptunCalendarLive> _neptuns = [];
    private readonly List<PersonalMoodleCalendarLive> _moodles = [];
    

}
