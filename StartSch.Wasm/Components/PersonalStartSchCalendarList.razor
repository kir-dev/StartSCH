@using System.Text.Json
@inject HttpClient HttpClient
@inject IJSRuntime Js

<div style="display: flex; flex-direction: column; gap: 16px; margin: 16px">
    <h2>StartSCH esemény kategóriák</h2>
    @foreach (var m in Models)
    {
        var model = m;
        <StartSchInput
            @key="@m"
            Model="@m"
            SaveCallback="@(() => Save(model))"
            DeleteCallback="@(() => Delete(model))"/>
    }
    <div style="display: flex; justify-content: center">
        <md-icon-button
            soft-disabled="@(_state != State.Default)"
            @onclick="@(async () =>
                      {
                          _state = State.AddDialogOpen;
                          await Js.InvokeVoidAsync("showDialog", _dialog);
                      })">
            <md-icon>
                add
            </md-icon>
        </md-icon-button>
    </div>
</div>

<md-dialog @ref="@_dialog" @onclose="@OnAddDialogClose">
    <div slot="headline">
        Új kategória létrehozása
    </div>
    <form slot="content" id="@_addDialogFormId" method="dialog">
        <MdFilledTextField
            label="Név"
            autofocus
            @bind-Value="@_addDialogModel.Name"
            style="display: flex"
            />
    </form>
    <div slot="actions">
        <md-text-button form="@_addDialogFormId">
            Mégse
        </md-text-button>
        <md-filled-button form="@_addDialogFormId" value="save">
            Mentés
        </md-filled-button>
    </div>
</md-dialog>

@code {
    private readonly Guid _addDialogFormId = Guid.NewGuid();
    
    private State _state = State.Default;
    private ElementReference _dialog;
    private PersonalStartSchCalendarLive _addDialogModel = new();
    
    [Parameter, EditorRequired] public required List<PersonalStartSchCalendarLive> Models { get; set; }
    [Parameter, EditorRequired] public EventCallback<PersonalCalendarLive> DeleteCallback { get; set; }
    [Parameter, EditorRequired] public EventCallback<PersonalCalendarLive> SaveCallback { get; set; }

    private async Task OnAddDialogClose()
    {
        string returnValue = await Js.InvokeAsync<string>("dialogGetReturnValue", _dialog);
       
        if (returnValue == "save")
        {
            _state = State.Saving;
            try
            {
                await Save(_addDialogModel);
                Models.Add(_addDialogModel);
                _addDialogModel = new();
            }
            catch (Exception e)
            {
                Console.WriteLine(e);
            }
        }

        _state = State.Default;
    }

    private async Task Save(PersonalStartSchCalendarLive model)
    {
        using var responseMessage =
            await HttpClient.PutAsJsonAsync("/calendars/personal", model, JsonSerializerOptions.Web);
        responseMessage.EnsureSuccessStatusCode();
        if (model.Id == 0)
        {
            var response = await responseMessage.Content.ReadFromJsonAsync<PersonalStartSchCalendarLive>();
            model.Id = response!.Id;
        }
    }
    
    private async Task Delete(PersonalStartSchCalendarLive model)
    {
        Models.Remove(model);
        using var responseMessage = await HttpClient.DeleteAsync($"/calendars/personal/{model.Id}");
        responseMessage.EnsureSuccessStatusCode();
    }

    private enum State
    {
        Default,
        AddDialogOpen,
        Saving
    }
}
