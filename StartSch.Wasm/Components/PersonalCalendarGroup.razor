@inject IJSRuntime Js
@typeparam TCalendar where TCalendar : PersonalCalendarLive

<div class="component" show-border="@ShowBorder">
    <header style="display: flex; justify-content: space-between; align-items: center; margin: 16px">
        <h3>
            @Title
        </h3>

        <md-filled-icon-button @onclick="@OpenInCalendarCallback">
            <md-icon>
                calendar_today
            </md-icon>
        </md-filled-icon-button>
    </header>

    <div class="items">
        @for (var i = 0; i < Items.Count; i++)
        {
            var item = Items[i];
            int index = i;
            <div class="item">
                <div style="display: flex; flex-direction: column; gap: 16px">
                    @ItemTemplate(item)
                </div>
                <div style="display: flex; flex-direction: column; gap: 8px">
                    <md-filled-tonal-icon-button>
                        <md-icon>
                            calendar_today
                        </md-icon>
                    </md-filled-tonal-icon-button>
                    <md-icon-button
                        @onclick="@(() =>
                                  {
                                      Items.RemoveAt(index);
                                      return DeleteCallback.InvokeAsync(item);
                                  })">
                        <md-icon>
                            delete
                        </md-icon>
                    </md-icon-button>
                </div>
            </div>
        }
    </div>

    <div style="display: flex; justify-content: center; margin: 4px">
        <md-icon-button
            soft-disabled="@(_state != State.Default)"
            @onclick="@(async () =>
                      {
                          _state = State.AddDialogOpen;
                          await Js.InvokeVoidAsync("showDialog", _dialog);
                      })">
            <md-icon>
                add
            </md-icon>
        </md-icon-button>
    </div>
</div>

<md-dialog @ref="@_dialog" @onclose="@OnAddDialogClose">
    <div slot="headline">
        @AddDialogHeadline
    </div>
    <form slot="content" id="@_addDialogFormId" method="dialog">
        @AddDialogContent
    </form>
    <div slot="actions">
        <md-text-button form="@_addDialogFormId">
            Mégse
        </md-text-button>
        <md-filled-button form="@_addDialogFormId" value="save">
            Mentés
        </md-filled-button>
    </div>
</md-dialog>

@code {
    private readonly Guid _addDialogFormId = Guid.NewGuid();

    private State _state = State.Default;
    private ElementReference _dialog;

    [Parameter, EditorRequired] public required string Title { get; set; }
    [Parameter, EditorRequired] public required List<TCalendar> Items { get; set; }
    [Parameter, EditorRequired] public required RenderFragment<TCalendar> ItemTemplate { get; set; }
    [Parameter, EditorRequired] public EventCallback<PersonalCalendarLive> SaveCallback { get; set; }
    [Parameter, EditorRequired] public EventCallback<PersonalCalendarLive> DeleteCallback { get; set; }
    [Parameter, EditorRequired] public required RenderFragment AddDialogHeadline { get; set; }
    [Parameter, EditorRequired] public required RenderFragment AddDialogContent { get; set; }
    [Parameter, EditorRequired] public required EventCallback<PersonalCalendarLive> AddCallback { get; set; }
    [Parameter, EditorRequired] public required EventCallback OpenInCalendarCallback { get; set; }
    [Parameter] public bool ShowBorder { get; set; } = true;
    
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Block the native submit event from escaping the inner form
            await Js.InvokeVoidAsync("stopSubmitBubbling", _dialog);
        }
    }

    private async Task OnAddDialogClose()
    {
        string returnValue = await Js.InvokeAsync<string>("dialogGetReturnValue", _dialog);

        if (returnValue == "save")
        {
            _state = State.Saving;
            try
            {
                await AddCallback.InvokeAsync();
            }
            catch (Exception e)
            {
                Console.WriteLine(e);
            }
        }

        _state = State.Default;
    }

    private enum State
    {
        Default,
        AddDialogOpen,
        Saving
    }

}
