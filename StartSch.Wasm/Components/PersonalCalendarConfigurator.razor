@using System.Text.Json
@inject HttpClient HttpClient

@if (_aesKey == null)
{
    if (HasAesKey)
    {
        <p>
            A külső naptárjaid linkjeit titkosítva tároljuk, hogy egy esetleges biztonsági incidens során se
            kerülhessenek nyilvánosságra. A titkosításhoz használt kulcsot a StartSCH naptár export linkek tartalmazzák.
            Ahhoz, hogy módosítani tudd a naptáradat, másold ide az egyik export URL-t a Google Naptáradból:
        </p>
        <input @bind="@_exportUrl" />
        <expressive-button class="small round filled" soft-disabled="@(string.IsNullOrWhiteSpace(_exportUrl))">
            <md-icon slot="icon">check</md-icon>
            Tovább
        </expressive-button>
        
        return;
    }
}

<h2>PersonalCalendarConfigurator</h2>
<div style="display: grid; grid-template-columns: 1fr 1fr">
    <div>
    </div>
    <div>
        2
    </div>
</div>

@code {
    private byte[]? _aesKey;
    private string? _encryptionToken;

    private string? _exportUrl;
    
    [Parameter, EditorRequired] public bool HasAesKey { get; set; }
    [Parameter, EditorRequired] public byte[]? InitialAesKey { get; set; }

    private async Task ResetEncryptionKey()
    {
        using var response = await HttpClient.PostAsync("/calendars/personal/reset-encryption-key", null);
        var result = await response.Content.ReadFromJsonAsync<ResetEncryptionKeyResult>(JsonSerializerOptions.Web);
        _aesKey = result!.AesKey;
        _encryptionToken = result.EncryptionToken;
    }
}
