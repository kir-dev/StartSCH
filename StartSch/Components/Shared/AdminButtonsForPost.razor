@using StartSch.Services
@inject AdministrationAuthorizationService AdministrationAuthorizationService

<AdminButtons
    EditUrl="@(
             AdministrationAuthorizationService.CanEdit(Post)
                 ? $"/posts/{Post.Id}/edit"
                 : null
             )"
/>

@code {
    [Parameter, EditorRequired] public required Post Post { get; set; }
}
