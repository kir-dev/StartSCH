@{
    TextContent content = new(Post.ContentMarkdown ?? "", Post.ExcerptMarkdown);
}

@* Open Android notification *@
@if (Post.Published == null) // no notification when editing after publishing
{
    <AdminContentPreview Title="Android értesítés">
        <div style="
                background-color: var(--md-sys-color-surface-container-high);
                border-radius: 28px;
                padding: 52px 22px 52px 52px;
                max-width: 400px;
                ">
            <h4 class="roboto-medium" style="margin: 0 128px 8px 0; font-size: 18px">
                @(Post.Title)
            </h4>
            <p class="roboto-regular"
               style="
                    color: var(--md-sys-color-on-surface-variant);
                    white-space: pre-wrap;
                    margin: 4px 0 0 0;
                    font-size: 15px;
                    max-height: 10lh;
                    overflow: hidden">(@(string.Join(", ", Post.GetOwners().Select(p => p.GetName())))) @content.TextExcerpt</p>
        </div>
    </AdminContentPreview>
}

@* Home page post *@
<AdminContentPreview Title="StartSCH főoldal">
    <div style="background-color: var(--sch-comp-card-container-color); padding: 32px">
        <PostPreview Post="@Post" HideAdminControls="@true"/>
    </div>
</AdminContentPreview>

@* Post page *@
<AdminContentPreview Title="StartSCH poszt oldal">
    <div style="background-color: var(--sch-comp-card-container-color); padding: 32px">
        <PostView Post="@Post" HideAdminControls="@true"/>
    </div>
</AdminContentPreview>


@code {
    [Parameter, EditorRequired] public required Post Post { get; set; }
}
