@page "/events/{EventId:int}"

@using System.Data
@using NodaTime.Text
@using StartSch.Services

@inherits ResourcePage<Event>

@inject Db Db
@inject InterestService InterestService
@inject AuthorizationService AuthorizationService

@if (After != null)
{
    @if (_event != null)
    {
        <InfiniteList TItem="object"
                      FetchPage="FetchPage"
                      GetCursor="GetCursor"
                      BaseUrl="@($"/events/{EventId}")"
                      After="@After"
                      PageSize="30">
            <ItemTemplate>
                @switch (context)
                {
                    case Event e:
                        <EventPreviewTree Event="@e" ParentKnown="@true"/>
                        break;
                    case Post p:
                        <PostPreview Post="@p" EventKnown="@true"/>
                        break;
                }
            </ItemTemplate>
        </InfiniteList>
    }
}
else
{
    <LayoutView Layout="@typeof(MainLayout)">
        @if (!IsResourceAvailable(_event, AuthorizationService.CanRead, out var status))
        {
            <ResourceUnavailable Status="@status"/>
        }
        else
        {
            <PageTitle>@_event.Title</PageTitle>

            <main>
                <EventView Event="@_event"/>

                <hr>

                <div style="margin-top: 16px">
                    <InfiniteList TItem="object"
                                  FetchPage="FetchPage"
                                  GetCursor="GetCursor"
                                  BaseUrl="@($"/events/{EventId}")"
                                  PageSize="30">
                        <ItemTemplate>
                            @switch (context)
                            {
                                case Event e:
                                    <EventPreviewTree Event="@e" ParentKnown="@true"/>
                                    break;
                                case Post p:
                                    <PostPreview Post="@p" EventKnown="@true"/>
                                    break;
                            }
                        </ItemTemplate>
                    </InfiniteList>
                </div>
            </main>
        }
    </LayoutView>
}

@code {
    private Event? _event;

    [Parameter] public int EventId { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "after")]
    public string? After { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await InterestService.LoadIndex;

        await using var tx = await Db.BeginTransaction(IsolationLevel.Snapshot);

        _event = await Db.Events
            .Include(e => e.Parent)
            .Include(e => e.EventCategories)
            .FirstOrDefaultAsync(e => e.Id == EventId);
        StateHasChanged();

        if (_event == null)
        {
            await tx.CommitAsync();
            return;
        }

        await Db.Events
            .GetDescendants(_event.Id)
            .Include(e => e.EventCategories)
            .LoadAsync();
        StateHasChanged();

        await Db.Posts
            .GetPostsForEvent(_event.Id)
            .Include(p => p.PostCategories)
            .LoadAsync();
        StateHasChanged();

        await tx.CommitAsync();
    }

    private async Task<List<object>> FetchPage(string? after)
    {
        Instant? afterInstant = null;
        int afterId = 0;

        if (after != null)
        {
            int comma = after.IndexOf(',');
            afterInstant = InstantPattern.ExtendedIso.Parse(after[..comma]).GetValueOrThrow();
            afterId = int.Parse(after.AsSpan(comma + 1));
        }

        IQueryable<Event> eventsQuery = Db.Events.Where(e => e.ParentId == EventId);
        IQueryable<Post> postsQuery = Db.Posts.Where(p => p.EventId == EventId);

        if (afterInstant.HasValue)
        {
            Instant cursor = afterInstant.Value;
            eventsQuery = eventsQuery.Where(e => e.Start < cursor || (e.Start == cursor && e.Id < afterId));
            postsQuery = postsQuery.Where(p => p.Created < cursor || (p.Created == cursor && p.Id < afterId));
        }

        var events = await eventsQuery
            .OrderByDescending(e => e.Start)
            .ThenByDescending(e => e.Id)
            .Take(30)
            .ToListAsync();

        var posts = await postsQuery
            .OrderByDescending(p => p.Created)
            .ThenByDescending(p => p.Id)
            .Take(30)
            .ToListAsync();

        return events.Cast<object>()
            .Concat(posts)
            .OrderByDescending(o => o switch
            {
                Event e => e.Start,
                Post p => p.Created,
                _ => throw new InvalidOperationException()
            })
            .ThenByDescending(o => o switch
            {
                Event e => e.Id,
                Post p => p.Id,
                _ => throw new InvalidOperationException()
            })
            .Take(30)
            .ToList();
    }

    private string GetCursor(object item) => item switch
    {
        Event e => $"{InstantPattern.ExtendedIso.Format(e.Start!.Value)},{e.Id}",
        Post p => $"{InstantPattern.ExtendedIso.Format(p.Created)},{p.Id}",
        _ => throw new InvalidOperationException()
    };

}
