@page "/events/{EventId:int}"

@using System.Data
@using NodaTime.Text
@using StartSch.Services

@inherits ResourcePage<Event>

@inject Db Db
@inject InterestService InterestService
@inject AuthorizationService AuthorizationService

@if (After != null)
{
    @if (_event != null)
    {
        <InfiniteList TItem="@Event"
                      FetchPage="FetchPage"
                      GetCursor="GetCursor"
                      BaseUrl="@($"/events/{EventId}")"
                      After="@After"
                      PageSize="30">
            <ItemTemplate>
                <EventPreviewTree Event="@context" ParentKnown="@true"/>
            </ItemTemplate>
        </InfiniteList>
    }
}
else
{
    <LayoutView Layout="@typeof(MainLayout)">
        @if (!IsResourceAvailable(_event, AuthorizationService.CanRead, out var status))
        {
            <ResourceUnavailable Status="@status"/>
        }
        else
        {
            <PageTitle>@_event.Title</PageTitle>

            <main>
                <EventView Event="@_event"/>

                <hr>

                <div style="margin-top: 16px">
                    <InfiniteList TItem="@Event"
                                  FetchPage="FetchPage"
                                  GetCursor="GetCursor"
                                  BaseUrl="@($"/events/{EventId}")"
                                  PageSize="30">
                        <ItemTemplate>
                            <EventPreviewTree Event="@context" ParentKnown="@true"/>
                        </ItemTemplate>
                    </InfiniteList>
                </div>
            </main>
        }
    </LayoutView>
}

@code {
    private Event? _event;

    [Parameter] public int EventId { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "after")]
    public string? After { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await InterestService.LoadIndex;

        await using var tx = await Db.BeginTransaction(IsolationLevel.Snapshot);

        _event = await Db.Events
            .Include(e => e.Parent)
            .Include(e => e.EventCategories)
            .FirstOrDefaultAsync(e => e.Id == EventId);
        StateHasChanged();

        if (_event == null)
        {
            await tx.CommitAsync();
            return;
        }

        await Db.Events
            .GetDescendants(_event.Id)
            .Include(e => e.EventCategories)
            .LoadAsync();
        StateHasChanged();

        await Db.Posts
            .GetPostsForEvent(_event.Id)
            .Include(p => p.PostCategories)
            .LoadAsync();
        StateHasChanged();

        await tx.CommitAsync();
    }

    private async Task<List<Event>> FetchPage(string? after)
    {
        await InterestService.LoadIndex;

        await using var tx = await Db.BeginTransaction(IsolationLevel.Snapshot);

        IQueryable<Event> eventQueryable = Db.Events
            .OrderByDescending(p => p.Start)
            .ThenByDescending(p => p.Id);
        if (After != null)
        {
            int comma = After.IndexOf(',');
            Instant date = InstantPattern.ExtendedIso.Parse(After[..comma]).Value;
            int postId = int.Parse(After.AsSpan(comma + 1));
            eventQueryable = eventQueryable.Where(p => p.Start < date || (p.Start == date && p.Id < postId));
        }
        var events = await eventQueryable
            .Take(30)
            .Include(o => o.EventCategories)
            .Include(p => p.Posts)
            .AsSplitQuery()
            .ToListAsync();
        await tx.CommitAsync();

        return events;
    }

    private string GetCursor(Event item) => $"{InstantPattern.ExtendedIso.Format(item.Start!.Value)},{item.Id}";
    

}
