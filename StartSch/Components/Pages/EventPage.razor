@page "/events/{EventId:int}"

@using System.Data
@using NodaTime.Text
@using StartSch.Services

@inherits ResourcePage<Event>

@inject Db Db
@inject InterestService InterestService
@inject AuthorizationService AuthorizationService

@if (After != null)
{
    @if (_event != null)
    {
        <InfiniteList TItem="object"
                      FetchPage="FetchPage"
                      GetCursor="GetCursor"
                      BaseUrl="@($"/events/{EventId}")"
                      After="@After"
                      PageSize="30">
            <ItemTemplate>
                @switch (context)
                {
                    case Event e:
                        <EventPreviewTree Event="@e" ParentKnown="@true"/>
                        break;
                    case Post p:
                        <PostPreview Post="@p" EventKnown="@true"/>
                        break;
                }
            </ItemTemplate>
        </InfiniteList>
    }
}
else
{
    <LayoutView Layout="@typeof(MainLayout)">
        @if (!IsResourceAvailable(_event, AuthorizationService.CanRead, out var status))
        {
            <ResourceUnavailable Status="@status"/>
        }
        else
        {
            <PageTitle>@_event.Title</PageTitle>

            <main>
                <EventView Event="@_event"/>

                <hr>

                <div style="margin-top: 16px">
                    <InfiniteList TItem="object"
                                  FetchPage="FetchPage"
                                  GetCursor="GetCursor"
                                  BaseUrl="@($"/events/{EventId}")"
                                  PageSize="30">
                        <ItemTemplate>
                            @switch (context)
                            {
                                case Event e:
                                    <EventPreviewTree Event="@e" ParentKnown="@true"/>
                                    break;
                                case Post p:
                                    <PostPreview Post="@p" EventKnown="@true"/>
                                    break;
                            }
                        </ItemTemplate>
                    </InfiniteList>
                </div>
            </main>
        }
    </LayoutView>
}

@code {
    private Event? _event;

    [Parameter] public int EventId { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "after")]
    public string? After { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await InterestService.LoadIndex;

        await using var tx = await Db.BeginTransaction(IsolationLevel.Snapshot);

        _event = await Db.Events
            .Include(e => e.Parent)
            .Include(e => e.EventCategories)
            .FirstOrDefaultAsync(e => e.Id == EventId);
        StateHasChanged();

        if (_event == null)
        {
            await tx.CommitAsync();
            return;
        }

        await Db.Events
            .GetDescendants(_event.Id)
            .Include(e => e.EventCategories)
            .LoadAsync();
        StateHasChanged();

        await Db.Posts
            .GetPostsForEvent(_event.Id)
            .Include(p => p.PostCategories)
            .LoadAsync();
        StateHasChanged();

        await tx.CommitAsync();
    }

    private Task<List<object>> FetchPage(string? after)
    {
        IEnumerable<object> items = _event!.Children
            .Concat<object>(_event.Posts)
            .OrderByDescending(o => o switch
            {
                Event e => e.Start,
                Post p => p.Created,
                _ => throw new InvalidOperationException()
            });

        if (after != null)
        {
            int comma = after.IndexOf(',');
            Instant afterInstant = InstantPattern.ExtendedIso.Parse(after[..comma]).GetValueOrThrow();
            int afterId = int.Parse(after.AsSpan(comma + 1));
            items = items.Where(o => IsAfterCursor(o, afterInstant, afterId));
        }

        return Task.FromResult(items.Take(30).ToList());
    }

    private static bool IsAfterCursor(object o, Instant afterInstant, int afterId) => o switch
    {
        Event e => e.Start < afterInstant || (e.Start == afterInstant && e.Id < afterId),
        Post p => p.Created < afterInstant || (p.Created == afterInstant && p.Id < afterId),
        _ => false
    };

    private string GetCursor(object item) => item switch
    {
        Event e => $"{InstantPattern.ExtendedIso.Format(e.Start!.Value)},{e.Id}",
        Post p => $"{InstantPattern.ExtendedIso.Format(p.Created)},{p.Id}",
        _ => throw new InvalidOperationException()
    };

}
