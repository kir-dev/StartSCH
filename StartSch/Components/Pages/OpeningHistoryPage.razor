@page "/openings"

@using NodaTime.Text
@using StartSch.Services

@inject Db Db
@inject InterestService InterestService

@if (After != null)
{
    <InfiniteList TItem="PincerOpening"
                  FetchPage="FetchPage"
                  GetCursor="GetCursor"
                  BaseUrl="/openings"
                  After="@After"
                  PageSize="30">
        <ItemTemplate>
            <EventPreview Event="context"/>
        </ItemTemplate>
    </InfiniteList>
}
else
{
    <LayoutView Layout="@typeof(MainLayout)">
        <h1>Nyitások</h1>
        <InfiniteList TItem="PincerOpening"
                      FetchPage="FetchPage"
                      GetCursor="GetCursor"
                      BaseUrl="/openings"
                      PageSize="30">
            <ItemTemplate>
                <EventPreview Event="context"/>
            </ItemTemplate>
        </InfiniteList>
    </LayoutView>
}

@code {
    [Parameter, SupplyParameterFromQuery(Name = "after")]
    public string? After { get; set; }

    private async Task<List<PincerOpening>> FetchPage(string? after)
    {
        await InterestService.LoadIndex;

        IQueryable<PincerOpening> query = Db.PincerOpenings
            .Where(o => o.End != null)
            .OrderByDescending(o => o.Start)
            .ThenByDescending(o => o.Id)
            .Include(o => o.EventCategories);

        if (after != null)
        {
            int comma = after.IndexOf(',');
            Instant afterInstant = InstantPattern.ExtendedIso.Parse(after[..comma]).GetValueOrThrow();
            int afterId = int.Parse(after.AsSpan(comma + 1));
            query = query.Where(o => o.Start < afterInstant || (o.Start == afterInstant && o.Id < afterId));
        }

        return await query.Take(30).ToListAsync();
    }

    private string GetCursor(PincerOpening opening) =>
        $"{InstantPattern.ExtendedIso.Format(opening.Start!.Value)},{opening.Id}";
}
