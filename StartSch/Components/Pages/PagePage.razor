@page "/pages/{PageId:int}"

@using System.Data
@using System.Text.Json
@using NodaTime.Text
@using StartSch.Services

@inherits ResourcePage<Page>

@inject Db Db
@inject InterestService InterestService
@inject AuthorizationService AuthorizationService

@if (After != null)
{
    <InfiniteList TItem="object"
                  FetchPage="FetchPage"
                  GetCursor="GetCursor"
                  BaseUrl="@($"/pages/{PageId}")"
                  After="@After"
                  PageSize="30">
        <ItemTemplate>
            @switch (context)
            {
                case Post post:
                    <PostPreview Post="@post" KnownPageId="@PageId"/>
                    break;
                case Event e:
                    <EventPreviewTree Event="@e" KnownPageId="@PageId"/>
                    break;
            }
        </ItemTemplate>
    </InfiniteList>
}
else
{
    <LayoutView Layout="@typeof(MainLayout)">
        @if (!IsResourceAvailable(_page, AuthorizationService.CanRead, out var status))
        {
            <ResourceUnavailable Status="@status"/>
            return;
        }

        <main>
            <article class="post">
                <header class="display">
                    <Title>@(_page.GetName())</Title>
                </header>

                <page-interests page="@_page.Id">
                    <ul class="label-list">
                        @if (_page.PekId.HasValue)
                        {
                            <li class="label">
                                <md-icon>account_circle</md-icon>
                                <a href="https://pek.sch.bme.hu/groups/@_page.PekId">
                                    PéK
                                    <span style="color: var(--md-sys-color-outline); font-weight: 400">/</span>
                                    @(_page.PekName ?? _page.PekId.ToString())
                                </a>
                            </li>
                        }

                        @if (_page.PincerId.HasValue)
                        {
                            <li class="label">
                                <md-icon>restaurant</md-icon>
                                <a href="https://schpincer.sch.bme.hu/provider/@_page.PincerId">
                                    SCH-Pincér
                                    <span style="color: var(--md-sys-color-outline); font-weight: 400">/</span>
                                    @(_page.PincerName ?? _page.PincerId.ToString())
                                </a>
                            </li>
                        }

                        @if (_page.ExternalUrl is { } url)
                        {
                            <li class="label">
                                <md-icon>link_2</md-icon>
                                <a href="@url">
                                    @url.TryRemoveFromStart("https://").ToString()
                                </a>
                            </li>
                        }
                    </ul>
                </page-interests>

                @{
                    var canCreateEvent = AuthorizationService.CanCreateEvent(_page);
                    var canCreatePost = AuthorizationService.CanCreatePost(_page);
                    // TODO what role should be required to accept collaboration requests ASK ALBI
                    var canAcceptCollaborationRequests = canCreatePost && canCreateEvent;
                }
                @if (canCreateEvent || canCreatePost || canAcceptCollaborationRequests)
                {
                    <div style="margin-top: 16px; display: flex; gap: 8px">
                        @{
                            var defaultCategory = _page.Categories.Single(c => c.Name == null);
                        }
                        @if (canCreateEvent)
                        {
                            <expressive-button href="@($"/events/0/edit?categories={defaultCategory.Id}")"
                                               class="small filled round">
                                <md-icon slot="icon">calendar_add_on</md-icon>
                                <span>
                                    Új esemény
                                </span>
                            </expressive-button>
                        }
                        @if (canCreatePost)
                        {
                            <expressive-button href="@($"/posts/0/edit?categories={defaultCategory.Id}")"
                                               class="small tonal round">
                                <md-icon slot="icon">chat_add_on</md-icon>
                                Új poszt
                            </expressive-button>
                        }
                        @if (canAcceptCollaborationRequests)
                        {
                            <expressive-button href="@($"/collaborations/{PageId}")" class="small text round">
                                <md-icon slot="icon">chat_info</md-icon>
                                Kollaborációs kérelmek
                            </expressive-button>
                        }
                    </div>
                }
            </article>

            <hr>

            <section>
                <h2>Történet</h2>
                <InfiniteList TItem="object"
                              FetchPage="FetchPage"
                              GetCursor="GetCursor"
                              BaseUrl="@($"/pages/{PageId}")"
                              PageSize="30">
                    <ItemTemplate>
                        @switch (context)
                        {
                            case Post post:
                                <PostPreview Post="@post" KnownPageId="@PageId"/>
                                break;
                            case Event e:
                                <EventPreviewTree Event="@e" KnownPageId="@PageId"/>
                                break;
                        }
                    </ItemTemplate>
                </InfiniteList>
            </section>
        </main>
    </LayoutView>
}

@code {
    private Page? _page;
    private readonly Instant currentInstant = SystemClock.Instance.GetCurrentInstant();

    [Parameter] public int PageId { get; set; }

    [Parameter, SupplyParameterFromQuery(Name = "after")]
    public string? After { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await InterestService.LoadIndex;

        _page = await Db.Pages.FirstOrDefaultAsync(g => g.Id == PageId);
    }

    private async Task<List<object>> FetchPage(string? after)
    {
        await InterestService.LoadIndex;

        await using var tx = await Db.BeginTransaction(IsolationLevel.Snapshot);

        IQueryable<Post> posts = Db.Posts
            .WhereAnyoneCanRead(currentInstant)
            .Where(p => p.Categories.Any(c => c.PageId == PageId))
            .Include(p => p.Categories)
            .Include(p => p.Event)
            .OrderByDescending(p => p.Published ?? p.Created);
        
        IQueryable<Event> events = Db.Events
            .Where(e => e.Categories.Any(c => c.PageId == PageId))
            .Include(e => e.EventCategories)
            .Include(e => e.Posts)
            .OrderByDescending(e => e.Start ?? e.Created);
        
        IQueryable<object> query = posts.Concat<object>(events)
            .OrderByDescending(o => GetDate(o));

        List<object> pageItems = [];
        
        if (after != null)
        {
            int comma = after.IndexOf(',');
            Instant afterInstant = InstantPattern.ExtendedIso.Parse(after[..comma]).GetValueOrThrow();
            int afterId = int.Parse(after.AsSpan(comma + 1));
            posts = posts.Where(p => 
                (p.Published ?? p.Created) < afterInstant || 
                ((p.Published ?? p.Created) == afterInstant && p.Id < afterId));
            events = events.Where(e => 
                (e.Start ?? e.Created) < afterInstant || 
                ((e.Start ?? e.Created) == afterInstant && e.Id < afterId));
            // baseQuery = baseQuery.Where(r => r.ObjDate < afterInstant || (r.ObjDate == afterInstant && r.Id < afterId));
        }
        
        pageItems.AddRange(await posts.Take(30).ToListAsync());
        pageItems.AddRange(await events.Take(30).ToListAsync());
        pageItems = pageItems
            .OrderByDescending(o => GetDate(o))
            .Take(30)
            .ToList();

        await tx.CommitAsync();

        return pageItems;
    }

    private bool IsAfterCursor(object o, Instant afterInstant, int afterId) => o switch
    {
        Post p => GetDate(p) < afterInstant || (GetDate(p) == afterInstant && p.Id < afterId),
        Event e => GetDate(e) < afterInstant || (GetDate(e) == afterInstant && e.Id < afterId),
        _ => false
    };

    private string GetCursor(object item) => item switch
    {
        Post post => $"{InstantPattern.ExtendedIso.Format(GetDate(post))},{post.Id}",
        Event e => $"{InstantPattern.ExtendedIso.Format(GetDate(e))},{e.Id}",
        _ => throw new InvalidOperationException()
    };

    private static Instant GetDate(object item) => item switch
    {
        Post post => post.Published ?? post.Created,
        Event @event => @event.Start ?? @event.Created,
        _ => throw new InvalidOperationException()
    };

}
