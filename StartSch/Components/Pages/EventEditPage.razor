@page "/events/{EventId:int}/edit"

@using NodaTime.Extensions
@using StartSch.Components.Shared.AdminPages
@using StartSch.Services

@rendermode InteractiveServerWithoutPrerendering
@layout DocumentLayout
@inherits ResourcePage<Event>

@inject IDbContextFactory<Db> DbFactory
@inject NavigationManager Navigation
@inject IServiceProvider ServiceProvider
@inject AuthorizationService AuthorizationService
@inject InterestService InterestService

@if (!IsResourceAvailable(
         _event,
         AuthorizationService.CanEdit,
         out var unavailableStatus
     ))
{
    <ResourceUnavailable Status="@unavailableStatus"/>
    return;
}

@{
    Instant currentInstant = SystemClock.Instance.GetCurrentInstant();
}

<AdminShell Title="@(_event.Id == 0 ? "Új esemény" : "Esemény szerkesztés")">
    <Form>
        <EditForm Model="@_model" OnValidSubmit="@OnValidSubmit" FormName="EventEditor">

            <div style="margin-top: 8px">
                <label>
                    <span style="display: block">
                        Cím
                    </span>
                    <InputText @bind-Value="@_model.Title" class="block"/>
                </label>
            </div>

            <div>
                <label>
                    <span style="display: block">
                        Szülő esemény
                    </span>
                    <InputSelect @bind-Value="@_model.ParentId">
                        <option value=""></option>
                        @foreach (var e in _possibleParents)
                        {
                            <option value="@e.Id">
                                @e.Title
                                @if (e.Start.HasValue)
                                {
                                    @: - @DateFormatter.Format(e.Start.Value, e.End, currentInstant)
                                }
                            </option>
                        }
                    </InputSelect>
                </label>
            </div>

            <div style="margin-top: 16px;">
                <div class="small filled round">
                    Kollaboráló körök
                </div>


                @if (GetSelectedCollaborationPages().Count > 0)
                {
                    <div style="margin-top: 8px;">
                        <md-chip-set aria-label="Kiválasztott kollaboráló körök" style="display: flex; flex-wrap: wrap; gap: 8px;">
                            @foreach (var collabPage in GetSelectedCollaborationPages())
                            {
                                <md-input-chip remove-only @onclick="() => RemoveCollaborationPage(collabPage)">
                                    @if (RequiresCollaborationRequest(collabPage))
                                    {
                                        <md-icon slot="icon" title="Kollaborációs kérelmet igényel">pending</md-icon>
                                    }
                                    @collabPage.GetName()
                                </md-input-chip>
                            }
                        </md-chip-set>
                    </div>
                }

                <div style="margin-top: 12px; display: flex; gap: 8px; align-items: center;">
                    <expressive-button type="button" class="small text round" @onclick="OpenPagePicker">
                        <md-icon slot="icon">add</md-icon>
                        Kör hozzáadása
                    </expressive-button>
                </div>

                @if (GetPagesRequiringRequest().Count > 0)
                {
                    <p class="small text" style="margin-top: 8px;">
                        <md-icon style="vertical-align: middle;">pending</md-icon>
                        Kollaborációs kérelmet igényel:
                        @string.Join(", ", GetPagesRequiringRequest().Select(p => p.GetName()))
                    </p>
                }
            </div>

            <div style="margin-top: 8px">
                <label>
                    <span style="display: block">
                        Kezdete
                    </span>
                    <InputDate TValue="@(DateTime?)" @bind-Value="@_model.Start" Type="@InputDateType.DateTimeLocal"/>
                </label>
            </div>

            <div style="margin-top: 8px">
                <label>
                    <span style="display: block">
                        Vége
                    </span>
                    <InputDate TValue="@(DateTime?)" @bind-Value="@_model.End" Type="@InputDateType.DateTimeLocal"/>
                </label>
            </div>

            <div style="margin-top: 8px">
                <label>
                    <span style="display: block">
                        Leírás
                        <small>(Markdown/HTML)</small>
                    </span>
                    <InputTextArea
                        style="min-height: 256px; font-family: monospace"
                        @bind-Value="@_model.DescriptionMarkdown"/>
                </label>
            </div>

            <div style="display: flex; gap: 8px; margin-top: 8px">
                <expressive-button type="submit" disabled="@_isBusy" class="small filled round">
                    <md-icon slot="icon">save</md-icon>
                    Mentés
                </expressive-button>

                @if (EventId != 0)
                {
                    <div style="flex: 1"></div>
                    <expressive-button href="@($"/events/{_event.Id}/delete")" class="small text round error standard"
                                       disabled="@_isBusy">
                        <md-icon slot="icon">delete</md-icon>
                        Törlés
                    </expressive-button>
                }
            </div>
        </EditForm>
    </Form>

    <Previews>
        @{
            _event.Start = _model.Start?.ToLocalDateTime().InZoneLeniently(Utils.HungarianTimeZone).ToInstant();
            _event.End = _model.End?.ToLocalDateTime().InZoneLeniently(Utils.HungarianTimeZone).ToInstant();
            _event.Title = _model.Title;
            _event.DescriptionMarkdown = _model.DescriptionMarkdown;
        }
        <EventEditPreview Event="@_event"/>
    </Previews>
</AdminShell>

@if (_isPagePickerOpen)
{
    <md-dialog open @onclose="ClosePagePicker">
        <h2 slot="headline" style="margin: 0; line-height: 1.35; padding-top: 8px; padding-left: 16px; padding-bottom: 4px;">
            Kör hozzáadása
        </h2>

        <form slot="content" id="event-page-picker-form" method="dialog" style="margin: 0; padding-top: 4px;">
            @if (GetAddablePages().Count == 0)
            {
                <p>Nincs több hozzáadható kör.</p>
            }
            else
            {
                <md-list style="max-width: 100%;">
                    @foreach (var addablePage in GetAddablePages())
                    {
                        <md-list-item>
                            <div slot="headline">@addablePage.GetName()</div>
                            @if (RequiresCollaborationRequest(addablePage))
                            {
                                <div slot="supporting-text">Kollaborációs kérelmet igényel</div>
                                <md-icon slot="start" title="Kollaborációs kérelmet igényel">pending</md-icon>
                            }
                            <md-text-button slot="end" @onclick="() => AddCollaborationPage(addablePage.Id)">
                                Hozzáadás
                            </md-text-button>
                        </md-list-item>
                    }
                </md-list>
            }

            <p class="small text" style="margin-top: 12px;">
                <md-icon style="vertical-align: middle;">pending</md-icon>
                Az ikonnal jelölt körök hozzáadása kollaborációs kérelmet hoz létre.
            </p>
        </form>

        <div slot="actions">
            <md-text-button form="event-page-picker-form" @onclick="ClosePagePicker">Bezárás</md-text-button>
        </div>
    </md-dialog>
}

@code {
    private Event? _event;
    private Page? _parentPage;
    private readonly List<Event> _possibleParents = [];
    private readonly EventEditModel _model = new();
    private bool _isBusy;
    private bool _isPagePickerOpen;
    private List<Page> _allPages = [];

    [Parameter] public int EventId { get; set; }

    [SupplyParameterFromQuery(Name = "categories")]
    public string? CategoryIds { get; set; }

    [SupplyParameterFromQuery(Name = "parent")]
    public int? ParentId { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();

        _allPages = await db.Pages
            .Include(p => p.Categories)
            .OrderBy(p => p.Name ?? p.PekName ?? p.PincerName)
            .ToListAsync();

        if (EventId == 0)
        {
            Event? parent = ParentId.HasValue
                ? await db.Events
                    .Include(p => p.Categories)
                    .ThenInclude(c => c.Page)
                    .FirstOrDefaultAsync(e => e.Id == ParentId)
                : null;

            if (ParentId.HasValue && parent == null)
                return;

            var newEvent = new Event
            {
                Start = SystemClock.Instance.GetCurrentInstant(),
                Title = "",
                ParentId = parent?.Id,
                Parent = parent,
            };

            if (string.IsNullOrEmpty(CategoryIds))
                return;

            List<int> categoryIds = CategoryIds.Split(',').Select(int.Parse).ToList();
            List<Category> categories = await db.Categories
                .Include(c => c.Page)
                .Where(c => categoryIds.Contains(c.Id))
                .ToListAsync();
            newEvent.Categories.AddRange(categories);

            _event = newEvent;
        }
        else
        {
            _event = await db.Events
                .Include(e => e.Parent)
                .Include(e => e.Categories)
                .ThenInclude(c => c.Page)
                .FirstOrDefaultAsync(e => e.Id == EventId);
            if (_event == null)
                return;

            _model.CollaborationCategories = _event.Categories.ToList();

            var requestedPageIds = await db.EventCollaborationRequests
                .Where(r => r.EventId == _event.Id)
                .Select(r => r.PageId)
                .Distinct()
                .ToListAsync();

            var requestedCategories = await db.Categories
                .Include(c => c.Page)
                .Where(c => requestedPageIds.Contains(c.PageId) && c.Name == null)
                .ToListAsync();

            foreach (var category in requestedCategories)
            {
                if (_model.CollaborationCategories.All(c => c.Id != category.Id))
                    _model.CollaborationCategories.Add(category);
            }
        }

        _model.Start = (_event.Start ?? SystemClock.Instance.GetCurrentInstant())
            .InZone(Utils.HungarianTimeZone)
            .ToDateTimeUnspecified();
        _model.End = _event.End?
                         .InZone(Utils.HungarianTimeZone)
                         .ToDateTimeUnspecified()
                     ?? _model.Start;
        _model.Title = _event.Title;
        _model.DescriptionMarkdown = _event.DescriptionMarkdown;

        if (_event.Parent != null)
        {
            _possibleParents.Add(_event.Parent);
            _model.ParentId = _event.Parent.Id;
        }
    }

    private async Task OnValidSubmit()
    {
        if (_isBusy) return;
        _isBusy = true;

        await using var scope = ServiceProvider.CreateAsyncScope();
        var eventService = scope.ServiceProvider.GetRequiredService<EventService>();

        Event savedEvent = await eventService.Save(
            EventId,
            _model.ParentId,
            _model.CollaborationCategories.Select(c => c.Id).ToHashSet(),
            _model.Title,
            _model.DescriptionMarkdown,
            _model.Start?.ToLocalDateTime().InZoneLeniently(Utils.HungarianTimeZone).ToInstant(),
            _model.End?.ToLocalDateTime().InZoneLeniently(Utils.HungarianTimeZone).ToInstant()
        );

        Navigation.NavigateTo($"/events/{savedEvent.Id}");
    }

    private void OpenPagePicker() => _isPagePickerOpen = true;
    private void ClosePagePicker() => _isPagePickerOpen = false;

    private bool RequiresCollaborationRequest(Page page)
        => !AuthorizationService.AdministeredPageIds.Contains(page.Id);

    private List<Page> GetSelectedCollaborationPages()
    {
        var selectedPageIds = _model.CollaborationCategories.Select(c => c.PageId).ToHashSet();
        return _allPages.Where(p => selectedPageIds.Contains(p.Id)).ToList();
    }

    private List<Page> GetPagesRequiringRequest()
        => GetSelectedCollaborationPages().Where(RequiresCollaborationRequest).ToList();

    private List<Page> GetAddablePages()
    {
        var selectedPageIds = _model.CollaborationCategories.Select(c => c.PageId).ToHashSet();
        return _allPages.Where(p => !selectedPageIds.Contains(p.Id)).ToList();
    }

    private void AddCollaborationPage(int pageId)
    {
        var page = _allPages.FirstOrDefault(p => p.Id == pageId);
        var category = page?.Categories.FirstOrDefault(c => c.Name == null) ?? page?.Categories.FirstOrDefault();
        if (category == null)
            return;

        if (_model.CollaborationCategories.All(c => c.Id != category.Id))
            _model.CollaborationCategories.Add(category);

        _isPagePickerOpen = false;
    }

    private void RemoveCollaborationPage(Page page)
        => _model.CollaborationCategories.RemoveAll(c => c.PageId == page.Id);

    private class EventEditModel
    {
        public DateTime? Start
        {
            get;
            set
            {
                var oldVal = field;
                field = value;
                UpdateEnd(oldVal);
            }
        }

        public DateTime? End { get; set; }
        public int? ParentId { get; set; }
        public List<Category> CollaborationCategories { get; set; } = [];
        [Length(1, 100)] public string Title { get; set; } = "";
        [MaxLength(20000)] public string? DescriptionMarkdown { get; set; }

        private void UpdateEnd(DateTime? oldStart)
        {
            if (oldStart == null || End == null)
                return;
            TimeSpan eventLength = End.Value - oldStart.Value;
            End = Start + eventLength;
        }
    }

}
